# CHZZK 개발자센터(https://developers.chzzk.naver.com/application)에서 발급받은 값
CHZZK_CLIENT_ID=
CHZZK_CLIENT_SECRET=

# 개발자센터의 "로그인 리디렉션 URL"과 문자 단위로 정확히 일치해야 합니다.
CHZZK_REDIRECT_URI=http://localhost:3000/auth/callback

# `pnpm login` 이 열어줄 로컬 콜백 서버 포트 (CHZZK_REDIRECT_URI 의 포트와 맞추세요)
CHZZK_LOGIN_PORT=3000

# 발급된 토큰을 저장할 경로 (.gitignore 처리됨)
CHZZK_TOKEN_FILE=.tokens/chzzk.json

# 봇 명령어 접두사
BOT_COMMAND_PREFIX=!

# silent | error | warn | info | debug
LOG_LEVEL=info
